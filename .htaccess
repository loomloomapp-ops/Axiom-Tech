# Hostinger / Apache. Безпечні дефолти + кеш + gzip.

# Only modules we rely on; fail soft if missing.
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Force HTTPS
    RewriteCond %{HTTPS} !=on
    RewriteCond %{HTTP_HOST} !^localhost [NC]
    RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

    # Trailing slash off for non-existing paths (optional, safe)
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} (.+)/$
    RewriteRule ^ %1 [R=301,L]
</IfModule>

# --- Block direct access to sensitive files ---
<FilesMatch "^(config\.php|config\.example\.php|README\.md|composer\.(json|lock)|package\.(json|lock))$">
    Require all denied
</FilesMatch>

<IfModule mod_rewrite.c>
    RewriteRule ^lang/        - [F,L]
    RewriteRule ^partials/    - [F,L]
    RewriteRule ^leads/       - [F,L]
</IfModule>

# --- Compression ---
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json image/svg+xml
</IfModule>

# --- Cache static assets ---
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpeg              "access plus 1 year"
    ExpiresByType image/png               "access plus 1 year"
    ExpiresByType image/webp              "access plus 1 year"
    ExpiresByType image/svg+xml           "access plus 1 year"
    ExpiresByType image/x-icon            "access plus 1 year"
    ExpiresByType text/css                "access plus 1 month"
    ExpiresByType application/javascript  "access plus 1 month"
    ExpiresByType text/javascript         "access plus 1 month"
    ExpiresByType font/woff2              "access plus 1 year"
    ExpiresByType text/html               "access plus 1 hour"
</IfModule>

<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
    Header set Permissions-Policy "interest-cohort=(), camera=(), microphone=()"
</IfModule>

# --- Pretty defaults ---
DirectoryIndex index.php index.html
ErrorDocument 404 /index.php
